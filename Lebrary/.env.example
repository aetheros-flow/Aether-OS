# Copy this file to .env and fill in the values.
# .env is git-ignored.

# --- Google AI Studio — get a free key at https://aistudio.google.com/apikey ---
GEMINI_API_KEY=

# Optional: override the default Gemini model (defaults: gemini-2.5-flash,
# fallback to gemini-2.5-flash-lite and gemini-2.0-flash on failure).
# GEMINI_MODEL=gemini-2.5-flash

# --- Supabase — get these at https://supabase.com/dashboard/project/<id>/settings/api ---
# Public anon key + URL. Safe to expose client-side (RLS protects data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-role key — SERVER-SIDE ONLY. Bypasses RLS. Used by ingest scripts
# to insert books/authors without an authenticated user session. Never expose
# to the browser.
SUPABASE_SERVICE_ROLE_KEY=
